# Frontend (Vite) — zmienne środowiskowe
# Skopiuj do .env lub ustaw w panelu Vercel

# URL backendu Express (na Railway/Render) + /api
# Przykład: https://twoj-projekt.up.railway.app/api
VITE_API_URL=

# Backend (Express) — zmienne środowiskowe
# Ustaw w panelu Railway/Render (NIE w pliku w repo!)
# SUPABASE_URL=https://twoj-projekt.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=twoj_service_role_key
# JWT_SECRET=twoj_tajny_klucz_jwt
# ADMIN_PASSWORD=haslo_admina
# WORKER_PASSWORD=haslo_pracownika
# CORS_ORIGIN=https://twoj-frontend.vercel.app

# Slack Webhook URL dla powiadomień o pełnych pojemnikach
# Utwórz w Slack: https://api.slack.com/apps → Incoming Webhooks → dodaj webhook do kanału
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
